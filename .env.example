# Supabase (public — safe for client if needed later)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App auth (simple login until Supabase Auth migration)
APP_LOGIN_EMAIL=you@example.com
APP_LOGIN_PASSWORD=your-secure-password
SESSION_SECRET=generate-a-long-random-string-min-32-chars

# Default user ID (must match seed in migration)
APP_USER_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# App URL (used in emails and redirects)
APP_BASE_URL=http://localhost:3000

# Database direct connection (server/migrations only — NEVER expose to client)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Daily briefing automation (Phase 12)
DAILY_BRIEFING_SECRET=generate-another-long-random-string
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM_EMAIL=
DAILY_BRIEFING_TO_EMAIL=

# OpenAI (server-only — NEVER expose to client)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
